<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@drawable/splashcreenbackground"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">
    <ImageView
        android:id="@+id/campfire"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/campfire"
        android:contentDescription="@string/campfire_image"
        android:layout_marginTop="200dp"
        android:layout_marginStart="110dp"/>
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/campfiretitle"
        android:contentDescription="@string/campfire_title"
        app:layout_constraintTop_toBottomOf="@+id/campfire"
        android:layout_margin="25dp"/>
</LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>